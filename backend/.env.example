# Backend environment configuration.
# Copy this file to `backend/.env` and fill in real values.

# PostgreSQL connection string used by `backend/src/db.ts`.
# The app constructs a `pg.Pool` from this URL on first DB call.
DATABASE_URL=postgres://snake:snake@localhost:5432/snake

# Port the Express server listens on. Defaults to 8787 if unset.
# The frontend dev server proxies `/api` to this port (see frontend/vite.config.ts).
PORT=8787

# Optional override for the SNAKE token reward configuration (JSON).
# Shipped with T07/T08 — see README "Token Rewards" section.
# Example shape (subject to change):
# SNAKE_REWARD_CONFIG_JSON={"tiers":[{"min":0,"label":"bronze","multiplier":1}]}
